# Copy to .env and fill in. Used by `source .env && uv run harbor run -c configs/...`.
# Models are routed through OpenRouter so the comparison is apples-to-apples.
OPENROUTER_API_KEY=

# Optional: use providers directly instead of OpenRouter.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
